{
  "name": "@open-insight/sandbox-apple",
  "version": "0.0.0",
  "description": "Apple container CLI sandbox provider for Open Insight.",
  "homepage": "https://github.com/open-insight/open-insight#readme",
  "bugs": {
    "url": "https://github.com/open-insight/open-insight/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-insight/open-insight.git",
    "directory": "packages/sandbox-apple"
  },
  "files": [
    "dist/**/*.mjs",
    "dist/**/*.mjs.map",
    "dist/**/*.mts",
    "dist/**/*.mts.map",
    "src/**/*.ts"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": "./src/export.ts",
    "./internal": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./internal": "./dist/internal.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "latest",
    "bumpp": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform-node": "catalog:",
    "@open-insight/core": "workspace:*"
  }
}
