{
  "name": "@open-insight/eval",
  "version": "0.0.9",
  "description": "Evaluator framework for Open Insight — benchmarks, tasks, evaluation harnesses.",
  "homepage": "https://github.com/OpenInsightDev/open-insight#readme",
  "bugs": {
    "url": "https://github.com/OpenInsightDev/open-insight/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenInsightDev/open-insight.git",
    "directory": "packages/eval"
  },
  "files": [
    "dist/**/*.mjs",
    "dist/**/*.mjs.map",
    "dist/**/*.mts",
    "dist/**/*.mts.map",
    "src/**/*.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/export.ts",
    "./internal": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./internal": "./dist/internal.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@effect/opentelemetry": "4.0.0-beta.93",
    "@effect/platform-node": "4.0.0-beta.91",
    "@effect/vitest": "catalog:",
    "@open-insight/core": "workspace:*",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "ai": "^7.0.0",
    "effect": "catalog:",
    "hyparquet": "catalog:",
    "immer": "catalog:",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@effect/ai-openai": "4.0.0-beta.92",
    "@open-insight/utils": "workspace:*",
    "@types/node": "^25.6.2",
    "@types/picomatch": "^4.0.3",
    "@typescript/native-preview": "catalog:",
    "bumpp": "^11.1.0",
    "pathe": "catalog:",
    "typescript": "^5",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}