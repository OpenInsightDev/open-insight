{
  "name": "@open-insight/eval",
  "version": "0.0.17",
  "description": "Evaluator framework for Open Insight — benchmarks, tasks, evaluation harnesses.",
  "homepage": "https://github.com/OpenInsightDev/open-insight#readme",
  "bugs": {
    "url": "https://github.com/OpenInsightDev/open-insight/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenInsightDev/open-insight.git",
    "directory": "packages/eval"
  },
  "files": [
    "dist/**/*.mjs",
    "dist/**/*.mjs.map",
    "dist/**/*.mts",
    "dist/**/*.mts.map",
    "src/**/*.ts"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": "./src/export.ts",
    "./internal": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./internal": "./dist/internal.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@effect/ai-openai": "catalog:",
    "@effect/ai-openai-compat": "catalog:",
    "@effect/opentelemetry": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@open-insight/core": "workspace:*",
    "@opentelemetry/api-logs": "catalog:",
    "@opentelemetry/sdk-logs": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@opentelemetry/sdk-trace-web": "catalog:",
    "ai": "catalog:",
    "hyparquet": "catalog:",
    "immer": "catalog:",
    "picomatch": "catalog:",
    "smol-toml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/picomatch": "catalog:",
    "bumpp": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
